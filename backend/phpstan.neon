includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app

    # Start conservative. Ratchet up (5 → 6 …) as the baseline shrinks.
    level: 4

    # Pre-existing findings are frozen in phpstan-baseline.neon so CI only
    # fails on NEW errors. Regenerate deliberately: composer analyse -- --generate-baseline
